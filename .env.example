# Kopieer naar .env en vul aan. Commit nooit echte secrets.
DATABASE_URL="postgresql://strippen:strippen@localhost:5432/strippenkaart?schema=public"
REDIS_URL="redis://localhost:6379"

# Auth.js (v5) – genereer met: openssl rand -base64 32
AUTH_SECRET=""
APP_URL="http://localhost:3000"

# Mail (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
MAIL_FROM="Strippenkaart Manager <noreply@example.com>"

# HostBill API
HOSTBILL_API_URL="https://billing.example.com/admin/api.php"
HOSTBILL_API_ID=""
HOSTBILL_API_KEY=""
HOSTBILL_POLL_ENABLED="false"
HOSTBILL_POLL_INTERVAL_MIN="15"
# Optioneel: method-namen/filters afstemmen op jullie HostBill-instance
HOSTBILL_ORDERS_CALL="getOrders"
HOSTBILL_UPSELL_CALL="addOrder"
HOSTBILL_PAID_STATUSES="Active,Paid,Completed"

# Bedrijfslogica
LOW_BALANCE_THRESHOLD_MIN="60"
EXPIRY_REMINDER_DAYS="14"
